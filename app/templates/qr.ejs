<style>
  :root {
    color-scheme: dark;
    --wa-bg: #0b141a;
    --wa-card: #111b21;
    --wa-card-2: #1f2c33;
    --wa-text: #e9edef;
    --wa-muted: #aebac1;
    --wa-green: #25d366;
    --wa-green-2: #128c7e;
  }

  body {
    margin: 0;
    background: radial-gradient(circle at top right, #123326 0%, var(--wa-bg) 45%);
    color: var(--wa-text);
    font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .page {
    max-width: 56rem;
    margin: 2rem auto;
    padding: 1.5rem;
    border-radius: 0.9rem;
    background: linear-gradient(180deg, var(--wa-card) 0%, var(--wa-card-2) 100%);
    border: 1px solid #233138;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }

  .meta {
    color: var(--wa-muted);
  }

  .qr-image {
    display: block;
    max-width: 100%;
    width: min(26rem, 100%);
    border: 1px solid #2d3b42;
    border-radius: 0.55rem;
    background: #fff;
    padding: 0.6rem;
    box-sizing: border-box;
    margin: 0 auto 0.9rem;
  }

  a {
    color: var(--wa-green);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    color: #6cf09f;
    text-decoration: underline;
  }
</style>

<div class="page">
  <h1><%= appName %></h1>

  <% if (qr) { %>
    <h2>WhatsApp login QR</h2>
    <p class="meta">QR updates are applied automatically when backend state changes.</p>
    <% if (qrImagePath) { %>
      <img class="qr-image" src="<%= qrImagePath %>" alt="WhatsApp login QR image" />
    <% } else { %>
      <p class="meta">QR image renderer is not available yet.</p>
    <% } %>
    <p>
      <a href="https://qrcode.show/<%= encodeURIComponent(qr) %>" target="_blank" rel="noopener noreferrer">
        Open external QR renderer
      </a>
    </p>
  <% } else if (initialized) { %>
    <h2>WhatsApp client is connected</h2>
    <p class="meta">No QR code is required right now.</p>
  <% } else { %>
    <h2>Waiting for a QR code...</h2>
    <p class="meta">Refresh this page in a few seconds.</p>
  <% } %>

  <p class="meta">
    Bundled <code>whatsapp-web.js</code> version: <strong><%= whatsappWebJsVersion %></strong>
    |
    App version: <strong><%= appVersion %></strong>
    |
    Runtime port: <strong><%= appPort %></strong>
  </p>
</div>

<script>
  (function () {
    const getBasePath = () => {
      const pathname = location.pathname || "/";
      const segments = pathname.split("/").filter(Boolean);
      if (segments.length > 0 && segments[segments.length - 1] === "qr") {
        segments.pop();
      }
      return segments.length === 0 ? "/" : `/${segments.join("/")}/`;
    };

    const buildAppUrl = (relativePath) => {
      const sanitized = String(relativePath || "").replace(/^\/+/, "");
      return `${getBasePath()}${sanitized}`;
    };

    let ws = null;
    let reconnectTimer = null;

    const connect = () => {
      const protocol = location.protocol === "https:" ? "wss:" : "ws:";
      const wsUrl = new URL(
        buildAppUrl("api/v1/events/ws?events=qr,ready,disconnected"),
        location.origin,
      );
      wsUrl.protocol = protocol;
      ws = new WebSocket(wsUrl.toString());

      ws.addEventListener("message", (event) => {
        let payload;
        try {
          payload = JSON.parse(event.data);
        } catch (_) {
          return;
        }

        if (payload?.event === "qr" || payload?.event === "ready" || payload?.event === "disconnected") {
          location.reload();
        }
      });

      ws.addEventListener("close", () => {
        clearTimeout(reconnectTimer);
        reconnectTimer = setTimeout(connect, 2000);
      });
    };

    connect();
    window.addEventListener("beforeunload", () => {
      clearTimeout(reconnectTimer);
      if (ws) {
        ws.close();
      }
    });
  })();
</script>
