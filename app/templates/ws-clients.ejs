<style>
  :root {
    color-scheme: dark;
    --wa-bg: #0b141a;
    --wa-header: #0a1014;
    --wa-card: #111b21;
    --wa-text: #e9edef;
    --wa-muted: #8696a0;
    --wa-green: #25d366;
    --wa-tooltip-bg: rgba(15, 20, 23, 0.96);
  }

  body {
    margin: 0;
    background: var(--wa-bg);
    color: var(--wa-text);
    font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .shell {
    max-width: 78rem;
    margin: 0.9rem auto;
    border-radius: 0.4rem;
    overflow: hidden;
    background: var(--wa-card);
    border: 1px solid #1d2a30;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.38);
  }

  .fake-chat-header {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    gap: 0.78rem;
    align-items: center;
    background: var(--wa-header);
    padding: 0.9rem 0.95rem;
    border-bottom: 1px solid #1d2a30;
  }

  .back-link {
    color: #d4dee2;
    text-decoration: none;
    font-size: 1.95rem;
    line-height: 1;
    padding: 0 0.2rem;
  }

  .back-link:hover {
    color: #f2f7f9;
  }

  .avatar {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(150deg, #1f9a64, #39b278);
    color: #052e1d;
    font-weight: 700;
  }

  .heading-title {
    margin: 0;
    font-size: 1.9rem;
    line-height: 1.05;
    font-weight: 500;
  }

  .heading-subtitle {
    margin-top: 0.16rem;
    color: var(--wa-muted);
    font-size: 1rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .ghost-ui {
    opacity: 0.18;
    color: #e4eaed;
    cursor: not-allowed !important;
    position: relative;
  }

  .ghost-ui::after {
    content: attr(data-hint);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.35rem);
    transform: translateX(-50%);
    background: var(--wa-tooltip-bg);
    color: #d8dee2;
    border: 1px solid #304047;
    border-radius: 0.42rem;
    padding: 0.24rem 0.45rem;
    font-size: 0.74rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.14s linear 0.5s;
    z-index: 30;
  }

  .ghost-ui:hover::after {
    opacity: 1;
  }

  .header-action-icon {
    border: 0;
    background: transparent;
    color: #dbe4e8;
    font-size: 1.35rem;
    line-height: 1;
    padding: 0.1rem 0.2rem;
  }

  .content {
    padding: 1.1rem 1.2rem 1.3rem;
  }

  .meta {
    color: var(--wa-muted);
  }

  a {
    color: var(--wa-green);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    color: #6cf09f;
    text-decoration: underline;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.8rem;
    margin: 1rem 0 1.2rem;
  }

  .stat-box {
    border: 1px solid #2d3b42;
    border-radius: 0.55rem;
    background: #0f1519;
    padding: 0.65rem 0.8rem;
  }

  .stat-box strong {
    display: block;
    color: var(--wa-muted);
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.6rem;
    font-size: 0.92rem;
  }

  th,
  td {
    border-bottom: 1px solid #2d3b42;
    padding: 0.45rem 0.35rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    color: var(--wa-muted);
    font-weight: 600;
  }

  td.mono {
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      "Courier New",
      monospace;
  }
</style>

<div class="shell">
  <header class="fake-chat-header">
    <a class="back-link" href=".">←</a>
    <div class="avatar">SC</div>
    <div>
      <h1 class="heading-title">WebSocket stats</h1>
      <div class="heading-subtitle">3 online</div>
    </div>
    <div class="header-actions">
      <button
        class="header-action-icon ghost-ui"
        type="button"
        data-hint="just looks good, nothing to do here"
      >
        🎥
      </button>
      <button
        class="header-action-icon ghost-ui"
        type="button"
        data-hint="just looks good, nothing to do here"
      >
        ▾
      </button>
      <button
        class="header-action-icon ghost-ui"
        type="button"
        data-hint="just looks good, nothing to do here"
      >
        ⋮
      </button>
    </div>
  </header>

  <div class="content">
    <p><a href=".">Back</a></p>

    <div id="statsGrid" class="stats-grid"></div>

    <h2>Connected websocket clients</h2>
    <table>
      <thead>
        <tr>
          <th>Client ID</th>
          <th>Channel</th>
          <th>Remote</th>
          <th>Selected events</th>
          <th>In/Out</th>
          <th>Connected at</th>
          <th>Last in/out</th>
        </tr>
      </thead>
      <tbody id="clientsTbody">
        <tr>
          <td colspan="7" style="color: var(--wa-muted)">Loading...</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  (function () {
    const statsGrid = document.getElementById("statsGrid");
    const clientsTbody = document.getElementById("clientsTbody");

    const getBasePath = () => {
      const pathname = location.pathname || "/";
      const segments = pathname.split("/").filter(Boolean);
      if (segments.length > 0 && segments[segments.length - 1] === "ws-clients") {
        segments.pop();
      }
      return segments.length === 0 ? "/" : `/${segments.join("/")}/`;
    };

    const buildAppUrl = (relativePath) =>
      `${getBasePath()}${String(relativePath || "").replace(/^\/+/, "")}`;

    const renderStats = (payload) => {
      const totals = payload?.totals || {};
      const current = payload?.current || {};
      const cards = [
        ["Current clients", String(current.totalClients ?? 0)],
        ["Current event sockets", String(current.eventsClients ?? 0)],
        ["Current runtime sockets", String(current.runtimeClients ?? 0)],
        ["Total accepted", String(totals.totalConnectionsAccepted ?? 0)],
        ["Total closed", String(totals.totalConnectionsClosed ?? 0)],
        ["WS messages in", String(totals.messagesIn ?? 0)],
        ["WS messages out", String(totals.messagesOut ?? 0)],
        ["RPC requests", String(totals.rpcRequests ?? 0)],
        ["RPC errors", String(totals.rpcErrors ?? 0)],
      ];
      statsGrid.innerHTML = "";
      for (const [label, value] of cards) {
        const box = document.createElement("div");
        box.className = "stat-box";
        box.innerHTML = `<strong>${label}</strong><span class=\"mono\">${value}</span>`;
        statsGrid.appendChild(box);
      }
    };

    const renderClients = (payload) => {
      const clients = Array.isArray(payload?.clients) ? payload.clients : [];
      clientsTbody.innerHTML = "";
      if (clients.length === 0) {
        clientsTbody.innerHTML = '<tr><td colspan="7" class="meta">No websocket clients connected.</td></tr>';
        return;
      }

      for (const client of clients) {
        const tr = document.createElement("tr");
        const selectedEvents = Array.isArray(client.selectedEvents)
          ? client.selectedEvents.join(", ")
          : "-";
        tr.innerHTML = `
          <td class="mono">${client.id || "-"}</td>
          <td>${client.channel || "-"}</td>
          <td class="mono">${client.remoteAddress || "-"}</td>
          <td>${selectedEvents}</td>
          <td class="mono">${client.messagesIn ?? 0}/${client.messagesOut ?? 0}</td>
          <td class="mono">${client.connectedAt || "-"}</td>
          <td class="mono">${client.lastInType || "-"} | ${client.lastOutType || "-"}</td>
        `;
        clientsTbody.appendChild(tr);
      }
    };

    const loadSnapshot = async () => {
      const response = await fetch(buildAppUrl("api/v1/ws/clients"));
      const payload = await response.json();
      renderStats(payload);
      renderClients(payload);
    };

    loadSnapshot().catch((error) => {
      clientsTbody.innerHTML = `<tr><td colspan="7" class="meta">Failed to load websocket stats: ${error.message}</td></tr>`;
    });
    setInterval(() => {
      loadSnapshot().catch(() => {});
    }, 2000);
  })();
</script>
