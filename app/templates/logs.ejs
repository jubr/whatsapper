<style>
  :root {
    color-scheme: dark;
    --bg: #0b141a;
    --header: #0a1014;
    --panel: #111b21;
    --line: #1d2a30;
    --line-2: #2b3a41;
    --txt: #e9edef;
    --muted: #8696a0;
    --ok: #8ff0ad;
    --warn: #ffd58a;
    --err: #ff9ea1;
    --dbg: #8ed8ff;
    --trc: #bb9cff;
    --http: #6cd6ff;
    --ws: #ffb36b;
    --hb: #9ff7a7;
    --chip: #162129;
    --chip-on: #1f9a64;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--txt);
    font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .shell {
    width: 100vw;
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr;
    background: var(--panel);
  }

  .header {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 0.55rem;
    align-items: center;
    background: var(--header);
    border-bottom: 1px solid var(--line);
    padding: 0.55rem 0.65rem;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .back-link {
    color: #d4dee2;
    text-decoration: none;
    font-size: 1.5rem;
    line-height: 1;
    padding: 0 0.2rem;
  }

  .title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .meta {
    color: var(--muted);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .filter-toggle {
    border: 1px solid var(--line-2);
    background: #0f161b;
    color: #dce4e8;
    border-radius: 0.35rem;
    height: 1.9rem;
    min-width: 2.1rem;
    cursor: pointer;
    font-size: 1rem;
  }

  .filters {
    border-bottom: 1px solid var(--line);
    padding: 0.45rem 0.55rem;
    background: #0e171d;
    display: none;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .filters.open {
    display: flex;
  }

  .group {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .group-label {
    color: var(--muted);
    font-size: 0.78rem;
    margin-right: 0.15rem;
  }

  .chip {
    border: 1px solid var(--line-2);
    background: var(--chip);
    color: #cbd5db;
    border-radius: 999px;
    font-size: 0.73rem;
    padding: 0.12rem 0.5rem;
    cursor: pointer;
    user-select: none;
  }

  .chip.on {
    background: rgba(31, 154, 100, 0.28);
    border-color: #2f8f66;
    color: #9af8cc;
  }

  .search {
    border: 1px solid var(--line-2);
    background: #0f161b;
    color: var(--txt);
    border-radius: 0.35rem;
    padding: 0.28rem 0.45rem;
    min-width: 18rem;
    font-size: 0.78rem;
  }

  .search::placeholder {
    color: #72828c;
  }

  .log-box {
    margin: 0;
    padding: 0.2rem 0.25rem;
    overflow: auto;
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      "Courier New",
      monospace;
    font-size: 12px;
    line-height: 1.25;
  }

  .log-row {
    display: grid;
    grid-template-columns: auto auto auto auto auto minmax(0, 1fr);
    gap: 0.38rem;
    align-items: baseline;
    padding: 0.08rem 0.2rem;
    border-radius: 0.2rem;
    white-space: nowrap;
  }

  .log-row:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .ts {
    color: #97a7b1;
  }

  .lvl {
    font-weight: 700;
    width: 0.9rem;
    text-align: center;
  }

  .lvl-I { color: var(--ok); }
  .lvl-W { color: var(--warn); }
  .lvl-E { color: var(--err); }
  .lvl-D { color: var(--dbg); }
  .lvl-T { color: var(--trc); }

  .cat {
    color: #9eb0ba;
    text-transform: uppercase;
    font-size: 10px;
  }

  .cat-http { color: var(--http); }
  .cat-ws { color: var(--ws); }
  .cat-heartbeat { color: var(--hb); }

  .topic {
    color: #9ca9ff;
    max-width: 18rem;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .msg {
    color: #d9e2e7;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .details {
    color: #8da0ab;
    margin-left: 0.2rem;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: baseline;
    flex-wrap: nowrap;
    gap: 0.28rem;
  }

  .details-sep {
    color: #68808f;
  }

  .arg {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    min-width: 0;
    flex: 0 0 auto;
    white-space: nowrap;
    margin-right: 0.34rem;
  }

  .arg:last-child {
    margin-right: 0;
  }

  .arg-key {
    color: #83c7ff;
    line-height: 1.2;
  }

  .arg-sep {
    color: #7e97a6;
    margin: 0 0.07rem 0 0.03rem;
    line-height: 1.2;
  }

  .arg-value {
    color: #d4dde2;
    line-height: 1.2;
  }

  .arg-client .arg-key {
    color: #b9a8ff;
  }

  .arg-client .arg-value {
    color: #cabfff;
  }

  .hidden {
    display: none !important;
  }
</style>

<div class="shell">
  <header class="header">
    <a class="back-link" data-app-route="" href=".">←</a>
    <div class="title">Logs</div>
    <div class="meta" id="metaText">connecting...</div>
    <button id="filterToggle" class="filter-toggle" type="button" title="Toggle filters">⛃</button>
  </header>

  <div id="filters" class="filters">
    <div class="group">
      <span class="group-label">category</span>
      <button class="chip on" data-filter-cat="http" type="button">http</button>
      <button class="chip on" data-filter-cat="ws" type="button">ws</button>
      <button class="chip on" data-filter-cat="heartbeat" type="button">heartbeat</button>
    </div>
    <div class="group">
      <span class="group-label">level</span>
      <button class="chip on" data-filter-level="E" type="button">E</button>
      <button class="chip on" data-filter-level="W" type="button">W</button>
      <button class="chip on" data-filter-level="I" type="button">I</button>
      <button class="chip on" data-filter-level="D" type="button">D</button>
      <button class="chip on" data-filter-level="T" type="button">T</button>
    </div>
    <div class="group">
      <span class="group-label">search</span>
      <input
        id="searchInput"
        class="search"
        type="text"
        placeholder="AND terms, use -negativeterm"
      />
    </div>
  </div>

  <div id="logBox" class="log-box"></div>
</div>

<script>
  (function () {
    const logBox = document.getElementById("logBox");
    const metaText = document.getElementById("metaText");
    const filtersEl = document.getElementById("filters");
    const filterToggle = document.getElementById("filterToggle");
    const searchInput = document.getElementById("searchInput");
    const catChips = Array.from(document.querySelectorAll("[data-filter-cat]"));
    const levelChips = Array.from(document.querySelectorAll("[data-filter-level]"));
    let runtimeWs = null;
    let hasRenderedSnapshotLogs = false;
    const entries = [];
    const MAX_ROWS = 2000;
    const state = {
      cat: new Set(["http", "ws", "heartbeat"]),
      level: new Set(["E", "W", "I", "D", "T"]),
      searchInclude: [],
      searchExclude: [],
    };

    const getBasePath = () => {
      const pathname = location.pathname || "/";
      const segments = pathname.split("/").filter(Boolean);
      if (segments.length > 0 && segments[segments.length - 1] === "logs") {
        segments.pop();
      }
      return segments.length === 0 ? "/" : `/${segments.join("/")}/`;
    };

    const buildAppUrl = (relativePath) =>
      `${getBasePath()}${String(relativePath || "").replace(/^\/+/, "")}`;

    const levelToCode = (rawLevel) => {
      const normalized = String(rawLevel || "info").trim().toLowerCase();
      if (normalized.startsWith("err")) return "E";
      if (normalized.startsWith("warn")) return "W";
      if (normalized.startsWith("debug")) return "D";
      if (normalized.startsWith("trace")) return "T";
      return "I";
    };

    const detectCategory = (entry) => {
      const scope = String(entry?.details?.scope || "").toLowerCase();
      const msg = String(entry?.message || "").toLowerCase();
      if (scope === "heartbeat" || msg.includes("heartbeat")) return "heartbeat";
      if (msg.includes("http request")) return "http";
      if (msg.includes("websocket") || msg.includes("rpc")) return "ws";
      if (scope === "server") {
        if (entry?.details?.method || entry?.details?.path) return "http";
        if (entry?.details?.channel || entry?.details?.topic) return "ws";
      }
      return "ws";
    };

    const formatTimeShort = (iso) => {
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return "??:??:??";
      return d.toLocaleTimeString([], { hour12: false, hour: "2-digit", minute: "2-digit", second: "2-digit" });
    };

    const abbreviateClientId = (value) => {
      const text = String(value || "").trim();
      if (text.length <= 14) {
        return text;
      }
      return `${text.slice(0, 6)}..${text.slice(-4)}`;
    };

    const stringifyDetailValue = (value) => {
      if (value === null || value === undefined) {
        return "";
      }
      if (typeof value === "object") {
        return "[complex]";
      }
      return String(value).replace(/\s+/g, " ").trim();
    };

    const buildDetailArgs = (details, { abbreviateClient = false } = {}) => {
      if (!details || typeof details !== "object") {
        return [];
      }
      const ordered = [];
      let clientArg = null;
      Object.entries(details).forEach(([key, value]) => {
        if (key === "scope" || key === "topic") {
          return;
        }
        const rendered = stringifyDetailValue(value);
        if (!rendered) {
          return;
        }
        if (key === "clientId") {
          clientArg = {
            key,
            value: abbreviateClient ? abbreviateClientId(rendered) : rendered,
          };
          return;
        }
        ordered.push({ key, value: rendered });
      });
      // Keep clientId as the last argument for readability.
      if (clientArg) {
        ordered.push(clientArg);
      }
      return ordered;
    };

    const normalizeSearchTerms = (query) => {
      const include = [];
      const exclude = [];
      String(query || "")
        .trim()
        .toLowerCase()
        .split(/\s+/)
        .filter(Boolean)
        .forEach((term) => {
          if (term.startsWith("-") && term.length > 1) {
            exclude.push(term.slice(1));
          } else {
            include.push(term);
          }
        });
      state.searchInclude = include;
      state.searchExclude = exclude;
    };

    const makeSearchText = (normalized) => {
      const topic = normalized.topic || "";
      const details = normalized.detailsSearch || "";
      return `${normalized.message} ${details} ${topic} ${normalized.category} ${normalized.levelCode}`.toLowerCase();
    };

    const passesFilter = (normalized) => {
      if (!state.cat.has(normalized.category)) return false;
      if (!state.level.has(normalized.levelCode)) return false;
      const haystack = makeSearchText(normalized);
      for (const token of state.searchInclude) {
        if (!haystack.includes(token)) return false;
      }
      for (const token of state.searchExclude) {
        if (haystack.includes(token)) return false;
      }
      return true;
    };

    const renderRow = (normalized) => {
      const row = document.createElement("div");
      row.className = "log-row";
      if (!passesFilter(normalized)) {
        row.classList.add("hidden");
      }

      const ts = document.createElement("span");
      ts.className = "ts";
      ts.textContent = formatTimeShort(normalized.timestamp);
      ts.title = normalized.timestamp;

      const lvl = document.createElement("span");
      lvl.className = `lvl lvl-${normalized.levelCode}`;
      lvl.textContent = normalized.levelCode;

      const cat = document.createElement("span");
      cat.className = `cat cat-${normalized.category}`;
      cat.textContent = normalized.category;

      const topic = document.createElement("span");
      topic.className = "topic";
      topic.textContent = normalized.topic || "-";
      topic.title = normalized.topic || "";

      const msg = document.createElement("span");
      msg.className = "msg";
      msg.textContent = normalized.message;

      const details = document.createElement("span");
      details.className = "details";
      if (Array.isArray(normalized.detailsArgs) && normalized.detailsArgs.length > 0) {
        const sep = document.createElement("span");
        sep.className = "details-sep";
        sep.textContent = "|";
        details.appendChild(sep);
        normalized.detailsArgs.forEach((arg) => {
          const argWrap = document.createElement("span");
          argWrap.className = "arg";
          if (arg.key === "clientId") {
            argWrap.classList.add("arg-client");
          }
          const key = document.createElement("span");
          key.className = "arg-key";
          key.textContent = arg.key;
          const keySep = document.createElement("span");
          keySep.className = "arg-sep";
          keySep.textContent = ":";
          const value = document.createElement("span");
          value.className = "arg-value";
          value.textContent = arg.value;
          argWrap.appendChild(key);
          argWrap.appendChild(keySep);
          argWrap.appendChild(value);
          details.appendChild(argWrap);
        });
      }

      row.appendChild(ts);
      row.appendChild(lvl);
      row.appendChild(cat);
      row.appendChild(topic);
      row.appendChild(msg);
      row.appendChild(details);
      row.__normalized = normalized;
      return row;
    };

    const rerenderVisibility = () => {
      const rows = Array.from(logBox.children);
      rows.forEach((row) => {
        const visible = passesFilter(row.__normalized);
        row.classList.toggle("hidden", !visible);
      });
      metaText.textContent = `${entries.length} rows`;
    };

    const appendEntry = (entry) => {
      const normalized = {
        timestamp: String(entry?.timestamp || new Date().toISOString()),
        levelCode: levelToCode(entry?.level),
        category: detectCategory(entry),
        topic: String(entry?.details?.topic || ""),
        message: String(entry?.message || "log"),
        detailsArgs: buildDetailArgs(entry?.details, { abbreviateClient: true }),
        detailsSearch: buildDetailArgs(entry?.details, { abbreviateClient: false })
          .map((arg) => `${arg.key}:${arg.value}`)
          .join(" "),
      };
      entries.push(normalized);
      const row = renderRow(normalized);
      logBox.appendChild(row);
      while (entries.length > MAX_ROWS) {
        entries.shift();
        if (logBox.firstChild) logBox.removeChild(logBox.firstChild);
      }
      logBox.scrollTop = logBox.scrollHeight;
      metaText.textContent = `${entries.length} rows`;
    };

    const resetEntries = (list) => {
      entries.length = 0;
      logBox.innerHTML = "";
      (Array.isArray(list) ? list : []).forEach((entry) => appendEntry(entry));
      rerenderVisibility();
    };

    filterToggle.addEventListener("click", () => {
      filtersEl.classList.toggle("open");
    });

    catChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const cat = chip.getAttribute("data-filter-cat");
        if (!cat) return;
        if (state.cat.has(cat)) {
          state.cat.delete(cat);
          chip.classList.remove("on");
        } else {
          state.cat.add(cat);
          chip.classList.add("on");
        }
        rerenderVisibility();
      });
    });

    levelChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const lvl = chip.getAttribute("data-filter-level");
        if (!lvl) return;
        if (state.level.has(lvl)) {
          state.level.delete(lvl);
          chip.classList.remove("on");
        } else {
          state.level.add(lvl);
          chip.classList.add("on");
        }
        rerenderVisibility();
      });
    });

    searchInput.addEventListener("input", () => {
      normalizeSearchTerms(searchInput.value);
      rerenderVisibility();
    });

    const openRuntimeSocket = () => {
      const protocol = location.protocol === "https:" ? "wss" : "ws";
      const runtimeWsUrl = new URL(buildAppUrl("api/v1/wwebjs/ws"), location.origin);
      runtimeWsUrl.protocol = `${protocol}:`;
      runtimeWs = new WebSocket(runtimeWsUrl.toString());

      runtimeWs.addEventListener("open", () => {
        metaText.textContent = `${entries.length} rows · live`;
      });

      runtimeWs.addEventListener("close", () => {
        metaText.textContent = `${entries.length} rows · reconnecting`;
        setTimeout(openRuntimeSocket, 2000);
      });

      runtimeWs.addEventListener("error", () => {
        metaText.textContent = `${entries.length} rows · ws error`;
      });

      runtimeWs.addEventListener("message", (event) => {
        let payload;
        try {
          payload = JSON.parse(event.data);
        } catch (_) {
          appendEntry({
            timestamp: new Date().toISOString(),
            level: "warn",
            message: "Malformed websocket payload",
            details: { raw: String(event.data).slice(0, 400) },
          });
          return;
        }

        if (payload.type === "snapshot") {
          if (!hasRenderedSnapshotLogs && Array.isArray(payload.logs)) {
            resetEntries(payload.logs);
            hasRenderedSnapshotLogs = true;
          }
          return;
        }

        if (payload.type === "log") {
          appendEntry(payload);
        }
      });
    };

    openRuntimeSocket();
  })();
</script>
