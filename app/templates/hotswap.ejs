<style>
  :root {
    color-scheme: dark;
    --wa-bg: #0b141a;
    --wa-card: #111b21;
    --wa-card-2: #1f2c33;
    --wa-text: #e9edef;
    --wa-muted: #aebac1;
    --wa-green: #25d366;
    --wa-green-2: #128c7e;
  }

  body {
    margin: 0;
    background: radial-gradient(circle at top right, #123326 0%, var(--wa-bg) 45%);
    color: var(--wa-text);
    font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .page {
    max-width: 72rem;
    margin: 2rem auto;
    padding: 1.5rem;
    border-radius: 0.9rem;
    background: linear-gradient(180deg, var(--wa-card) 0%, var(--wa-card-2) 100%);
    border: 1px solid #233138;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }

  .meta {
    color: var(--wa-muted);
  }

  .toolbar {
    margin-bottom: 1rem;
  }

  .toolbar select,
  .toolbar button {
    border: 1px solid #2d3b42;
    border-radius: 0.45rem;
    background: #0f1519;
    color: var(--wa-text);
    padding: 0.45rem 0.65rem;
    font-size: 0.95rem;
  }

  .toolbar select {
    min-width: 28rem;
  }

  .toolbar button {
    cursor: pointer;
    margin-left: 0.35rem;
  }

  .toolbar button:hover:not(:disabled) {
    border-color: var(--wa-green);
    color: #6cf09f;
  }

  .toolbar button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .runtime-state {
    margin-bottom: 1rem;
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      "Courier New",
      monospace;
    color: #d7e5dc;
  }

  .log-box {
    border: 1px solid #2d3b42;
    padding: 0.75rem;
    background: #0f1519;
    color: #d7e5dc;
    height: 24rem;
    overflow-y: auto;
    white-space: pre-wrap;
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      "Courier New",
      monospace;
    border-radius: 0.55rem;
  }

  a {
    color: var(--wa-green);
    text-decoration: none;
    font-weight: 600;
  }

  a:hover {
    color: #6cf09f;
    text-decoration: underline;
  }
</style>

<div class="page">
  <h1><%= appName %>: hot swap <code>whatsapp-web.js</code></h1>

  <p class="meta">
    Bundled version at build time: <strong><%= whatsappWebJsVersion %></strong>
    |
    App version: <strong><%= appVersion %></strong>
    |
    Runtime port: <strong><%= appPort %></strong>
  </p>
  <p><a href=".">Back</a></p>

  <div class="toolbar">
    <label for="refSelect"><strong>Target ref</strong></label><br />
    <select id="refSelect"></select>
    <button id="applyButton">Apply</button>
    <button id="refreshButton">Refresh refs</button>
  </div>

  <div id="runtimeState" class="runtime-state"></div>

  <h2>Progress and connection status</h2>
  <div id="logBox" class="log-box"></div>
</div>

<script>
  (function () {
    const refSelect = document.getElementById("refSelect");
    const applyButton = document.getElementById("applyButton");
    const refreshButton = document.getElementById("refreshButton");
    const runtimeStateEl = document.getElementById("runtimeState");
    const logBox = document.getElementById("logBox");

    let runtimeState = null;
    let refsPayload = null;
    let runtimeWs = null;
    let hasRenderedSnapshotLogs = false;

    const getBasePath = () => {
      const pathname = location.pathname || "/";
      const segments = pathname.split("/").filter(Boolean);
      if (segments.length === 0) {
        return "/";
      }
      segments.pop();
      return segments.length === 0 ? "/" : `/${segments.join("/")}/`;
    };

    const buildAppUrl = (relativePath) => {
      const sanitized = String(relativePath || "").replace(/^\/+/, "");
      return `${getBasePath()}${sanitized}`;
    };

    const toDateString = (value) => {
      if (!value) return "n/a";
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? value : date.toISOString();
    };

    const appendLogLine = (line, level) => {
      const el = document.createElement("div");
      if (level === "error") {
        el.style.color = "#ff8f8f";
      } else if (level === "warn") {
        el.style.color = "#f8d66d";
      } else if (level === "info") {
        el.style.color = "#86efac";
      } else {
        el.style.color = "#ddd";
      }
      el.textContent = line;
      logBox.appendChild(el);
      logBox.scrollTop = logBox.scrollHeight;
    };

    const appendStructuredLog = (entry) => {
      const stamp = toDateString(entry.timestamp);
      const level = entry.level || "info";
      const message = entry.message || JSON.stringify(entry);
      appendLogLine(`[${stamp}] [${level}] ${message}`, level);
    };

    const renderRuntimeState = () => {
      if (!runtimeState) {
        runtimeStateEl.textContent = "Loading runtime state...";
        applyButton.disabled = true;
        return;
      }

      runtimeStateEl.textContent = [
        `appName=${runtimeState.appName}`,
        `appPort=${runtimeState.appPort}`,
        `currentChoice=${runtimeState.currentChoice}`,
        `installedVersion=${runtimeState.installedVersion}`,
        `initialized=${runtimeState.initialized}`,
        `swapping=${runtimeState.swapping}`,
        `dirtyBuild=${runtimeState.dirtyBuild}`,
      ].join(" | ");

      applyButton.disabled = Boolean(runtimeState.swapping);
      refSelect.disabled = Boolean(runtimeState.swapping);
    };

    const renderRefs = () => {
      if (!refsPayload) {
        return;
      }

      const previousChoice = runtimeState?.currentChoice || refSelect.value;
      refSelect.innerHTML = "";

      const allOptions = [refsPayload.builtIn, ...(refsPayload.refs || [])];

      for (const ref of allOptions) {
        const option = document.createElement("option");
        option.value = ref.choice;

        if (ref.type === "built-in") {
          option.textContent = `[built-in][marked] ${ref.label}`;
        } else {
          option.textContent = `[${ref.type}] ${ref.label} | ${toDateString(ref.updatedAt)}`;
        }

        if (ref.choice === previousChoice) {
          option.selected = true;
        }
        refSelect.appendChild(option);
      }
    };

    const handleSnapshot = (payload) => {
      runtimeState = payload.state || runtimeState;
      renderRuntimeState();

      if (!hasRenderedSnapshotLogs && Array.isArray(payload.logs)) {
        logBox.innerHTML = "";
        payload.logs.forEach((entry) => appendStructuredLog(entry));
        hasRenderedSnapshotLogs = true;
      }
    };

    const fetchRuntimeState = async () => {
      const response = await fetch(buildAppUrl("api/v1/wwebjs/runtime"));
      const payload = await response.json();
      runtimeState = payload;
      renderRuntimeState();
      renderRefs();
    };

    const fetchRefs = async (refresh = false) => {
      const response = await fetch(
        `${buildAppUrl("api/v1/wwebjs/refs")}${refresh ? "?refresh=1" : ""}`,
      );
      const payload = await response.json();
      refsPayload = payload;
      renderRefs();
    };

    const openRuntimeSocket = () => {
      const protocol = location.protocol === "https:" ? "wss" : "ws";
      const runtimeWsUrl = new URL(buildAppUrl("api/v1/wwebjs/ws"), location.origin);
      runtimeWsUrl.protocol = `${protocol}:`;
      runtimeWs = new WebSocket(runtimeWsUrl.toString());

      runtimeWs.addEventListener("open", () => {
        appendLogLine("[ws] Connected to runtime progress stream", "info");
      });

      runtimeWs.addEventListener("close", () => {
        appendLogLine("[ws] Disconnected from runtime stream. Reconnecting...", "warn");
        setTimeout(openRuntimeSocket, 2000);
      });

      runtimeWs.addEventListener("error", () => {
        appendLogLine("[ws] Runtime stream error", "error");
      });

      runtimeWs.addEventListener("message", (event) => {
        let payload;
        try {
          payload = JSON.parse(event.data);
        } catch (_) {
          appendLogLine(`[ws] ${event.data}`, "info");
          return;
        }

        if (payload.type === "snapshot") {
          handleSnapshot(payload);
          return;
        }

        if (payload.type === "refs") {
          refsPayload = payload.payload;
          renderRefs();
          return;
        }

        if (payload.type === "log") {
          appendStructuredLog(payload);
          return;
        }
      });
    };

    applyButton.addEventListener("click", async () => {
      const choice = refSelect.value;
      if (!choice) return;

      appendLogLine(`[ui] Applying choice: ${choice}`, "info");
      applyButton.disabled = true;

      try {
        const response = await fetch(buildAppUrl("api/v1/wwebjs/hotswap"), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ choice }),
        });
        const payload = await response.json();
        if (!response.ok) {
          appendLogLine(`[ui] Hotswap failed: ${payload.error || response.status}`, "error");
        } else {
          runtimeState = payload.result || runtimeState;
          renderRuntimeState();
          appendLogLine(`[ui] Hotswap request completed for ${choice}`, "info");
        }
      } catch (error) {
        appendLogLine(`[ui] Hotswap request error: ${error.message}`, "error");
      } finally {
        await fetchRuntimeState();
      }
    });

    refreshButton.addEventListener("click", async () => {
      appendLogLine("[ui] Refreshing refs from GitHub...", "info");
      try {
        await fetchRefs(true);
        if (runtimeWs && runtimeWs.readyState === runtimeWs.OPEN) {
          runtimeWs.send(JSON.stringify({ type: "refresh_refs" }));
        }
      } catch (error) {
        appendLogLine(`[ui] Ref refresh failed: ${error.message}`, "error");
      }
    });

    (async () => {
      await fetchRuntimeState();
      await fetchRefs(false);
      openRuntimeSocket();
    })().catch((error) => {
      appendLogLine(`[ui] Startup error: ${error.message}`, "error");
    });
  })();
</script>
